<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>Contact | SnipSnap</title>
  <link rel="stylesheet" href="/css/responsive-contact.css">

</head>
<body style="font-family: 'Segoe UI', sans-serif;">
  <%- include('./partials/nav') %>

  <div class="container my-5" style="max-width: 700px;">
    <h2 class="fw-bold mb-4 text-dark text-center">📬 Contact Us</h2>
    
    <p class="text-secondary text-center mb-4" style="font-size: 1.05rem;">
      Have questions, feedback, or issues? Fill out the form below or reach us directly via email.
    </p>

    <form action="/contact" method="POST">
      <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div class="alert alert-danger text-center rounded-3 fw-semibold shadow-sm mb-4" role="alert" style="font-size: 0.95rem;">
          <%= errorMessage %>
        </div>
      <% } %>

      <% if (typeof successMessage !== 'undefined' && successMessage) { %>
        <div class="alert alert-success text-center rounded-3 fw-semibold shadow-sm mb-4" role="alert" style="font-size: 0.95rem;">
          <%= successMessage %>
        </div>
      <% } %>

      <!-- Name -->
      <div class="mb-3">
        <label for="name" class="form-label fw-semibold text-secondary">Your Name</label>
        <input type="text" class="form-control" id="name" name="name" placeholder="Enter your name" style="padding: 10px; border-radius: 10px;" required>
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label for="email" class="form-label fw-semibold text-secondary">Your Email</label>
        <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" style="padding: 10px; border-radius: 10px;" required>
      </div>

      <!-- Message -->
      <div class="mb-4">
        <label for="message" class="form-label fw-semibold text-secondary">Message</label>
        <textarea class="form-control" id="message" name="message" rows="5" placeholder="Write your message here..." style="padding: 10px; border-radius: 10px;" required></textarea>
        <small class="text-muted d-block mt-2">Message must be at least 10 characters long.</small>
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-dark btn-lg rounded-3">Send Message</button>
      </div>
    </form>

    <div class="mt-5 text-center">
      <p class="text-secondary mb-1" style="font-size: 1rem;">Or email us at:</p>
      <p class="fw-semibold text-dark mb-0">📧 support@snipsnap.com</p>
      <p class="fw-semibold text-dark">📧 amanshow9800@gmail.com</p>
    </div>
  </div>

  <%- include('./partials/scripts') %>
  <%- include('./partials/footer') %>
</body>
</html>
