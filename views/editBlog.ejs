<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head") %>
  <title>Edit Blog | SnipSnap</title>
  <style>
    .form-label {
      font-weight: 600;
      color: #495057;
    }

    .form-control {
      padding: 12px;
      border-radius: 12px;
      border: 1px solid #ced4da;
      font-size: 1rem;
    }

    .form-control:focus {
      border-color: #212529;
      box-shadow: 0 0 0 0.15rem rgba(33, 37, 41, 0.25);
    }

    .btn-publish {
      background-color: #212529;
      color: #fff;
      font-weight: 600;
      font-size: 1.05rem;
      padding: 12px;
      border-radius: 12px;
      transition: background-color 0.2s ease;
    }

    .btn-publish:hover {
      background-color: #000;
    }

    .card-blog-form {
      max-width: 700px;
      border: none;
      border-radius: 20px;
      padding: 2.5rem;
    }
  </style>
</head>
<body class="bg-light" style="font-family: 'Segoe UI', sans-serif;">
  <%- include("./partials/nav") %>

  <div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh;">
    <div class="card shadow card-blog-form w-100">
      <h2 class="text-center mb-4 text-dark fw-bold" style="font-size: 2rem;">Edit Your Blog</h2>

      <form id="addBlogForm" action="/blog/<%= blog._id %>?_method=PUT" method="post" enctype="multipart/form-data" novalidate>
        <div class="mb-4">
          <label for="coverImage" class="form-label">Cover Image (optional)</label>
          <input type="file" class="form-control" id="coverImage" name="coverImage">
          <% if (blog.coverImageURL) { %>
            <small class="text-muted d-block mt-2">Current image will stay if no new file is uploaded.</small>
          <% } %>
        </div>

        <div class="mb-4">
          <label for="title" class="form-label">Title</label>
          <input type="text" class="form-control" id="title" name="title" maxlength="60" value="<%= blog.title %>" required>
          <div id="titleError" class="invalid-feedback d-none">
            Title is required and must be under 60 characters.
          </div>
        </div>

        <% const useCustomGenre = !genres.includes(blog.genre); %>
        <div class="mb-4">
          <label for="genre" class="form-label">Genre</label>
          <select class="form-select" id="genre" name="genre" required style="padding: 10px; border-radius: 10px;">
            <option value="" disabled>Select blog genre</option>
            <% genres.forEach((genreOption) => { %>
              <option value="<%= genreOption %>" <%= blog.genre === genreOption ? 'selected' : '' %>><%= genreOption %></option>
            <% }) %>
            <option value="other" <%= useCustomGenre ? 'selected' : '' %>>Other</option>
          </select>
          <div id="genreError" class="invalid-feedback d-none">
            Genre is required.
          </div>
        </div>

        <div class="mb-4 <%= useCustomGenre ? '' : 'd-none' %>" id="customGenreContainer">
          <label for="customGenre" class="form-label">Custom Genre</label>
          <input type="text" class="form-control" id="customGenre" name="customGenre" value="<%= useCustomGenre ? blog.genre : '' %>" placeholder="Enter a custom genre" style="padding: 10px; border-radius: 10px;" <%= useCustomGenre ? 'required' : '' %>>
          <div id="customGenreError" class="invalid-feedback d-none">
            Please enter a custom genre.
          </div>
        </div>

        <div class="mb-4">
          <label for="body" class="form-label">Body</label>
          <textarea name="body" class="form-control" id="body" rows="7" maxlength="25000" required><%= blog.body %></textarea>
          <div id="bodyError" class="invalid-feedback d-none">
            Body is required and must be under 25,000 characters.
          </div>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-publish">Save Changes</button>
          <a href="/blog/<%= blog._id %>" class="btn btn-outline-dark">Cancel</a>
        </div>
      </form>
    </div>
  </div>

  <%- include("./partials/scripts") %>
  <%- include("./partials/footer") %>
</body>
</html>
